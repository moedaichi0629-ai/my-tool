# 仮想環境（Pythonのライブラリ置き場 - GitHubにあげる必要なし）
venv/
.venv/
env/

# 秘密情報（APIキーなど - 絶対にGitHubにあげてはいけない）
.env
credentials.json
token.pickle
*.pickle

# 大きすぎるバイナリファイル（50MB超はGitHub非対応）
*.exe

# Pythonのキャッシュファイル（自動生成されるので不要）
__pycache__/
*.pyc
*.pyo

# 画像ファイル（容量が大きいため除外）
images/

# OS・エディタの自動生成ファイル
.DS_Store
Thumbs.db
