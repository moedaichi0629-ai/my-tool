# ============================================================
# .env 設定ファイルのテンプレート
# このファイルをコピーして「.env」という名前にし、
# 各値を自分のAPIキーに書き換えてください。
#
# Renderへデプロイする場合は .env は不要です。
# Renderのダッシュボードで Environment Variables に直接設定してください。
# ============================================================

# ──────────────────────────────────────────────────
# LINE Messaging API の設定
# 取得場所: https://developers.line.biz/console/
# ──────────────────────────────────────────────────

# チャンネルシークレット（LINE Developers → チャンネル基本設定 で確認）
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# チャンネルアクセストークン（長期）
# LINE Developers → Messaging API設定 → チャンネルアクセストークン で発行
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────
# OpenAI API の設定
# 取得場所: https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────

# APIキー（「sk-」から始まる文字列）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────
# Google Sheets の設定
# ──────────────────────────────────────────────────

# スプレッドシートのID
# Google スプレッドシートの URL から取得：
# https://docs.google.com/spreadsheets/d/【ここ】/edit
GOOGLE_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google サービスアカウントの認証情報（JSON全体を1行で貼り付け）
# credentials.json の中身を1行のJSON文字列としてここに貼り付けます
# 例: {"type": "service_account", "project_id": "...", "private_key_id": "...", ...}
#
# 【取得方法】
# 1. credentials.json をメモ帳などで開く
# 2. 内容を全選択してコピー
# 3. 改行を取り除いて1行にする（または下記コマンドを使用）
#    PowerShell: (Get-Content credentials.json -Raw) -replace "`r`n|`n", ""
# 4. その文字列をここに貼り付ける
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"xxx","private_key":"-----BEGIN RSA PRIVATE KEY-----\nxxx\n-----END RSA PRIVATE KEY-----\n","client_email":"xxx@xxx.iam.gserviceaccount.com","client_id":"xxx","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
