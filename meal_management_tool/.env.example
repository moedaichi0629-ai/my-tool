# ============================================================
# .env 設定ファイルのテンプレート
# このファイルをコピーして「.env」という名前にし、
# 各値を自分のAPIキーに書き換えてください。
# ============================================================

# ──────────────────────────────────────────────────
# LINE Messaging API の設定
# 取得場所: https://developers.line.biz/console/
# ──────────────────────────────────────────────────

# チャンネルシークレット（LINE Developers → チャンネル基本設定 で確認）
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# チャンネルアクセストークン（長期）
# LINE Developers → Messaging API設定 → チャンネルアクセストークン で発行
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────
# OpenAI API の設定
# 取得場所: https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────

# APIキー（「sk-」から始まる文字列）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────
# Google Sheets の設定
# ──────────────────────────────────────────────────

# スプレッドシートのID
# Google スプレッドシートの URL から取得：
# https://docs.google.com/spreadsheets/d/【ここ】/edit
GOOGLE_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
