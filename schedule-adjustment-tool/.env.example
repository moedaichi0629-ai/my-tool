# ============================================================
# 日程調整支援ツール 環境変数設定ファイル
# ============================================================
# このファイルをコピーして .env という名前で保存し、
# 各項目に実際の値を設定してください。
# .env ファイルは絶対にGitHubにpushしないでください！
# ============================================================

# OpenAI APIキー（送信用文章をAIで生成する場合に必要）
# https://platform.openai.com/api-keys で取得できます
# 設定しない場合はテンプレートベースの文章が生成されます
OPENAI_API_KEY=your_openai_api_key_here

# Google OAuthクライアントシークレットファイルのパス
# Google Cloud Consoleからダウンロードしたファイルの名前です
# デフォルト: client_secrets.json（プロジェクトフォルダ直下に配置）
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json

# OAuthのリダイレクトURI
# Streamlitのデフォルトポートが8501なのでそのまま使用してください
# Google Cloud ConsoleのリダイレクトURIと完全に一致させること
GOOGLE_REDIRECT_URI=http://localhost:8501
